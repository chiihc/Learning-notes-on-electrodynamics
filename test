    0&=(k-1)x_1^2-2(k+1)x_1d+(k-1)d^2+(k-1)x_2^2\\
    0&\xlongequal{u=\frac{k+1}{k-1}}x_1^2-2ux_1d+d^2+x_2^2\\
    u^2-d^2&=(x_1-u)^2+x_2^2
\end{align*}